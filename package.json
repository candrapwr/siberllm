{
  "name": "siberllm",
  "version": "0.1.0",
  "description": "SiberLLM — desktop layer UI for running llama.cpp as an OpenAI-compatible API server.",
  "author": "datasiberLab <candrapwr@datasiber.com>",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "icons": "./scripts/build-icons.sh",
    "package": "electron-vite build && electron-forge package",
    "make": "electron-vite build && electron-forge make",
    "make:dmg": "electron-vite build && electron-forge make --targets=dmg",
    "make:mac": "electron-vite build && electron-forge make --platform=darwin",
    "make:win": "electron-vite build && electron-forge make --platform=win32",
    "make:linux": "electron-vite build && electron-forge make --platform=linux",
    "publish": "electron-vite build && electron-forge publish"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^10.0.1",
    "react-router-dom": "^6.28.0",
    "tree-kill": "^1.2.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.1",
    "@electron-forge/maker-deb": "^7.6.1",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.6.1",
    "@electron-forge/maker-squirrel": "^7.6.1",
    "@electron-forge/maker-zip": "^7.6.1",
    "@electron-forge/publisher-github": "^7.11.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
